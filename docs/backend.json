
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "sex": { "type": "string", "enum": ["Male", "Female", "Others (LGBTQI++)"] },
        "roleId": { "type": "string" },
        "role": { "type": "string" },
        "campusId": { "type": "string" },
        "unitId": { "type": "string" },
        "verified": { "type": "boolean" },
        "ndaAccepted": { "type": "boolean" }
      },
      "required": ["id", "email", "firstName", "lastName", "roleId", "role", "campusId", "unitId", "verified"]
    },
    "UnitFormRequest": {
      "title": "UnitFormRequest",
      "description": "Application for enrolling or revising controlled quality forms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unitId": { "type": "string" },
        "unitName": { "type": "string" },
        "campusId": { "type": "string" },
        "submitterId": { "type": "string" },
        "submitterName": { "type": "string" },
        "scannedRegistrationFormLink": { "type": "string", "format": "uri", "description": "Link to signed DRF evidence." },
        "requestedForms": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "code": { "type": "string" },
              "link": { "type": "string" },
              "revision": { "type": "string" }
            }
          } 
        },
        "status": { "type": "string", "enum": ["Submitted", "QA Review", "Returned for Correction", "Awaiting Presidential Approval", "Approved & Registered"] },
        "comments": { "type": "array", "items": { "$ref": "#/backend/entities/Comment" } }
      }
    },
    "UnitForm": {
      "title": "UnitForm",
      "description": "An approved, controlled form available in a unit's active roster.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unitId": { "type": "string" },
        "formCode": { "type": "string" },
        "formName": { "type": "string" },
        "googleDriveLink": { "type": "string", "format": "uri" },
        "revision": { "type": "string" },
        "requestId": { "type": "string", "description": "The ID of the originating registration request." }
      }
    },
    "AuditPlan": {
      "title": "AuditPlan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "auditNumber": { "type": "string" },
        "auditType": { "type": "string", "enum": ["Regular Audit", "Special Audit"] },
        "title": { "type": "string" },
        "year": { "type": "number" },
        "campusId": { "type": "string" },
        "auditeeType": { "type": "array", "items": { "type": "string" } },
        "groupClauseMapping": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "scope": { "type": "string" },
        "leadAuditorId": { "type": "string" },
        "openingMeetingDate": { "type": "string", "format": "date-time" },
        "closingMeetingDate": { "type": "string", "format": "date-time" }
      }
    },
    "EmployeeActivity": {
      "title": "EmployeeActivity",
      "description": "Daily task log for university personnel.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "unitId": { "type": "string" },
        "campusId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "activityParticular": { "type": "string" },
        "status": { "type": "string", "enum": ["Completed", "In Progress", "Open", "Postponed"] },
        "output": { "type": "string" },
        "googleDriveLink": { "type": "string", "format": "uri", "description": "Link to verifiable evidence or output document." },
        "remarks": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "approvedBy": { "type": "string" },
        "approvedByName": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "startTime", "endTime", "activityParticular", "status"]
    },
    "QaAdvisory": {
      "title": "QaAdvisory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "controlNumber": { "type": "string" },
        "subject": { "type": "string" },
        "releaseDate": { "type": "string", "format": "date-time" },
        "googleDriveLink": { "type": "string", "format": "uri" },
        "scope": { "type": "string", "enum": ["University-Wide", "Specific Unit"] },
        "targetUnitId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["controlNumber", "subject", "releaseDate", "googleDriveLink", "scope"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Institutional user profiles." },
    "/unitFormRequests/{requestId}": { "schema": { "$ref": "#/backend/entities/UnitFormRequest" }, "description": "Applications for form registration." },
    "/unitForms/{formId}": { "schema": { "$ref": "#/backend/entities/UnitForm" }, "description": "Active roster of controlled forms." },
    "/auditPlans/{planId}": { "schema": { "$ref": "#/backend/entities/AuditPlan" }, "description": "High-level IQA frameworks." },
    "/employeeActivities/{activityId}": { "schema": { "$ref": "#/backend/entities/EmployeeActivity" }, "description": "Daily task logs." },
    "/qaAdvisories/{advisoryId}": { "schema": { "$ref": "#/backend/entities/QaAdvisory" }, "description": "QA communications." }
  }
}
