
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "sex": { "type": "string", "enum": ["Male", "Female", "Others (LGBTQI++)"] },
        "roleId": { "type": "string" },
        "role": { "type": "string" },
        "campusId": { "type": "string" },
        "unitId": { "type": "string" },
        "verified": { "type": "boolean" },
        "ndaAccepted": { "type": "boolean" }
      },
      "required": ["id", "email", "firstName", "lastName", "roleId", "role", "campusId", "unitId", "verified"]
    },
    "EmployeeActivity": {
      "title": "EmployeeActivity",
      "description": "Daily task log for university personnel.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "unitId": { "type": "string" },
        "campusId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "activityParticular": { "type": "string" },
        "status": { "type": "string", "enum": ["Completed", "In Progress", "Open", "Postponed"] },
        "output": { "type": "string" },
        "googleDriveLink": { "type": "string", "format": "uri", "description": "Link to verifiable evidence or output document." },
        "remarks": { "type": "string" }
      },
      "required": ["userId", "date", "startTime", "endTime", "activityParticular", "status"]
    },
    "QaAdvisory": {
      "title": "QaAdvisory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "controlNumber": { "type": "string" },
        "subject": { "type": "string" },
        "releaseDate": { "type": "string", "format": "date-time" },
        "googleDriveLink": { "type": "string", "format": "uri" },
        "scope": { "type": "string", "enum": ["University-Wide", "Specific Unit"] },
        "targetUnitId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["controlNumber", "subject", "releaseDate", "googleDriveLink", "scope"]
    },
    "Signatories": {
      "title": "Signatories",
      "type": "object",
      "properties": {
        "qaoDirector": { "type": "string" },
        "qmsHead": { "type": "string" },
        "accreditationHead": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GadSettings": {
      "title": "GadSettings",
      "type": "object",
      "properties": {
        "leadershipUnitId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Institutional user profiles." },
    "/employeeActivities/{activityId}": { "schema": { "$ref": "#/backend/entities/EmployeeActivity" }, "description": "Daily task logs." },
    "/qaAdvisories/{advisoryId}": { "schema": { "$ref": "#/backend/entities/QaAdvisory" }, "description": "QA communications." },
    "/system/signatories": { "schema": { "$ref": "#/backend/entities/Signatories" }, "description": "Institutional signatories." },
    "/system/gadSettings": { "schema": { "$ref": "#/backend/entities/GadSettings" }, "description": "GAD governance settings." }
  }
}
