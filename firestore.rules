
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && (
        profile().get('role', '').matches('(?i).*(director|odimo|admin).*') ||
        profile().get('role', '').matches('(?i).*vice president.*')
      );
    }

    // --------------------------------------------------------------------------
    // CORE WORKFLOW COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{id} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /unitForms/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{id} {
      allow get, list, write: if isSignedIn();
    }
    
    match /risks/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /employeeActivities/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /wfhActivities/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // --------------------------------------------------------------------------
    // ACADEMIC & PROGRAM MONITORING
    // --------------------------------------------------------------------------

    match /academicPrograms/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /programCompliances/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /unitMonitoringRecords/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSupervisor() || isAdmin();
    }

    // --------------------------------------------------------------------------
    // GAD & STRATEGIC HUB
    // --------------------------------------------------------------------------

    match /gadInitiatives/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /gadMainstreaming/{id} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isSupervisor() || profile().get('role', '').matches('(?i).*coordinator.*'));
      allow delete: if isAdmin();
    }

    match /gadActivities/{id} {
      allow get, list, delete: if isSignedIn();
      allow create: if true; // Support public device-based entry
      allow update: if isSignedIn();
    }

    match /unitPersonnelCensus/{id} {
      allow get, list, write: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // QA REPORTS, AUDITS & CARS
    // --------------------------------------------------------------------------

    match /auditPlans/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditSchedules/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /auditFindings/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /correctiveActionRequests/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /managementReviews/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /managementReviewOutputs/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /communications/{id} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (
        isAdmin() ||
        profile().get('role', '').matches('(?i).*(odimo|director|president|vice president|coordinator).*')
      );
      // Stamp-receive: any signed-in user can update only recipientRefNums and/or readBy.
      // Full edits require admin or an authorized role.
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipientRefNums', 'readBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipientRefNums']) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*(odimo|director|president|vice president|coordinator).*'))
      );
      allow delete: if isAdmin();
    }

    match /visitorLogs/{id} {
      allow read, write: if isSignedIn();
    }

    match /qaAdvisories/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // SYSTEM COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campuses/{id} { 
      allow read: if true; // Required for Registration dropdown
      allow write: if isAdmin(); 
    }
    
    match /units/{id} { 
      allow read: if true; // Required for Registration unit filter
      allow write: if isAdmin(); 
    }
    
    match /roles/{id} { 
      allow get, list: if true; // Required for Registration role selection
      allow write: if isAdmin(); 
    }
    
    match /cycles/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /isoClauses/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }

    match /system/{docId} {
      allow get: if isSignedIn() || docId == 'settings' || docId == 'logo'; 
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campusSettings/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /activityLogs/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /errorReports/{id} {
      allow create: if true;
      allow get, list: if isAdmin();
    }

    match /appFeedbacks/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /softwareEvaluations/{id} {
      allow create: if true; // Allow stakeholders to evaluate
      allow get, list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Admin-specific override for Form Roster Management
    match /unitForms/{allPaths=**} {
        allow write: if isAdmin();
    }

    // Explicit list permission for form registration tracking
    match /unitFormRequests {
        allow list: if isSignedIn();
    }

    // Final catch-all for anything else
    match /{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
