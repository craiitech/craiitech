
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Master Admin Check
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*(director|odimo|vice president|chair|dean).*');
    }

    // --------------------------------------------------------------------------
    // CORE COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /qaAuditReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviews/{mrId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviewOutputs/{outputId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
      allow update: if isSignedIn();
    }

    match /correctiveActionRequests/{carId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isAuditor();
      allow update: if isAdmin() || isAuditor() || 
        (hasProfile() && resource.data.unitId == profile().get('unitId', ''));
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || isAuditor() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.unitId == profile().get('unitId', '') || 
        resource.data.campusId == profile().get('campusId', '') ||
        isSupervisor()
      ));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isSupervisor()
      ));
      allow delete: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // MISC COLLECTIONS
    // --------------------------------------------------------------------------

    match /academicPrograms/{programId} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /programCompliances/{recordId} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /campuses/{campusId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{unitId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /qaAdvisories/{advisoryId} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{cycleId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /risks/{riskId} { allow read: if isAdmin() || isSupervisor() || (hasProfile() && resource.data.userId == request.auth.uid); allow write: if isAdmin() || (hasProfile() && request.resource.data.userId == request.auth.uid); }
  }
}
