
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '') in ['Admin', 'admin', 'Administrator', 'administrator', 'System Administrator', 'Super Admin'])
      );
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && (
        profile().get('role', '').matches('(?i).*(director|odimo|admin|dean of instruction|doi).*') ||
        profile().get('role', '').matches('(?i).*vice president.*') ||
        profile().get('unitId', '') == 'W61XJkVKga3ra2JaLINg' ||
        profile().get('unitName', '').matches('(?i).*(dean of instruction|doi).*')
      );
    }

    // --------------------------------------------------------------------------
    // CORE WORKFLOW COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{id} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /procedureRevisionRequests/{id} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /unitForms/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /pbbSubmissions/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /risks/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /employeeActivities/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /wfhActivities/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // --------------------------------------------------------------------------
    // ACADEMIC & PROGRAM MONITORING
    // --------------------------------------------------------------------------

    match /academicPrograms/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /programCompliances/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /unitMonitoringRecords/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSupervisor() || isAdmin();
    }

    // --------------------------------------------------------------------------
    // GAD & STRATEGIC HUB
    // --------------------------------------------------------------------------

    match /gadInitiatives/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /gadMainstreaming/{id} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isSupervisor() || profile().get('role', '').matches('(?i).*coordinator.*'));
      allow delete: if isAdmin();
    }

    match /gadActivities/{id} {
      allow get, list, delete: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /unitPersonnelCensus/{id} {
      allow get, list, write: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // QA REPORTS, AUDITS & CARS
    // --------------------------------------------------------------------------

    match /auditPlans/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditSchedules/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /auditFindings/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /clauseRevisits/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /correctiveActionRequests/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /managementReviews/{id} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /managementReviewOutputs/{id} {
      allow get, list, write: if isSignedIn();
    }

    match /communications/{id} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (
        isAdmin() ||
        profile().get('role', '').matches('(?i).*(odimo|director|president|vice president|coordinator).*')
      );
      // Stamp-receive: any signed-in user can update only recipientRefNums and/or readBy.
      // Full edits require admin or an authorized role.
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipientRefNums', 'readBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipientRefNums']) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*(odimo|director|president|vice president|coordinator).*'))
      );
      allow delete: if isAdmin();
    }

    match /visitorLogs/{id} {
      allow read, write: if isSignedIn();
    }

    match /qaAdvisories/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // SYSTEM COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campuses/{id} { 
      allow read: if true; // Required for Registration dropdown
      allow write: if isAdmin(); 
    }
    
    match /units/{id} { 
      allow read: if true; // Required for Registration unit filter
      allow write: if isAdmin(); 
    }
    
    match /roles/{id} { 
      allow get, list: if true; // Required for Registration role selection
      allow write: if isAdmin(); 
    }
    
    match /cycles/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /isoClauses/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow get, list: if isSignedIn(); allow write: if isAdmin(); }

    match /system/csmSettings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow get: if isSignedIn() || docId == 'settings' || docId == 'logo'; 
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /csmDeployments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && hasProfile() && profile().unitId == get(/databases/$(database)/documents/system/csmSettings).data.managingUnitId);
    }

    match /csmResponses/{id} {
      allow read, write: if isSignedIn();
    }

    match /campusSettings/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /unitCsmSettings/{unitId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() || 
        isSupervisor() || 
        (hasProfile() && profile().get('role', '').matches('(?i).*coordinator.*'))
      );
    }

    match /unitPersonnel/{id} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() || 
        isSupervisor() || 
        (hasProfile() && profile().get('role', '').matches('(?i).*coordinator.*'))
      );
    }

    match /activityLogs/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /errorReports/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /appFeedbacks/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /formDownloadLogs/{id} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }

    match /softwareEvaluations/{id} {
      allow create: if true; // Allow stakeholders to evaluate
      allow get, list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Admin-specific override for Form Roster Management
    match /unitForms/{allPaths=**} {
        allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // UNIT ACTIVITY & ATTENDANCE SYSTEM
    // --------------------------------------------------------------------------
    match /unitActivities/{id} {
      allow read: if true; // Public read: needed by evaluation QR portal (unauthenticated mobile users)
      allow write: if isSignedIn();
    }

    // Device bindings are immutable once created — prevents unbinding another user's device.
    // Required fields enforced to prevent garbage data.
    match /attendanceDeviceBindings/{id} {
      allow create: if true
        && request.resource.data.keys().hasAll(['userId', 'deviceFingerprint', 'userName', 'boundAt'])
        && request.resource.data.userId is string
        && request.resource.data.deviceFingerprint is string;
      allow read: if true;
      allow update, delete: if false;
    }

    // Attendance logs are immutable records. Once written, they cannot be modified or deleted.
    // Field validation ensures data integrity. Status must be one of the valid states.
    match /unitActivityAttendanceLogs/{id} {
      allow read: if true;
      allow create: if true
        && request.resource.data.keys().hasAll(['activityId', 'userId', 'status', 'scannedAt', 'deviceFingerprint'])
        && request.resource.data.activityId is string
        && request.resource.data.userId is string
        && request.resource.data.deviceFingerprint is string
        && request.resource.data.status in ['ON_TIME', 'LATE', 'OUTSIDE_WINDOW', 'REJECTED']
        && request.resource.data.scannedAt is number;
      allow update, delete: if false;
    }

    // Evaluations are submitted once — no editing after submission prevents tampering.
    // Field validation ensures all required data is present.
    match /unitActivityEvaluations/{id} {
      allow create: if true
        && request.resource.data.keys().hasAny(['ratingOverall', 'activityId', 'submittedAt'])
        && request.resource.data.activityId is string
        && request.resource.data.submittedAt is number;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // --------------------------------------------------------------------------
    // KPI & OKR Collections
    // --------------------------------------------------------------------------

    match /kpiDefinitions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /kpiSnapshots/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /kpiAlerts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /okrObjectives/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.ownerId
      );
      allow delete: if isAdmin();
    }

    match /okrKeyResults/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.ownerId
      );
      allow delete: if isAdmin();
    }

    match /okrCheckIns/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Final catch-all for anything else
    match /{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
