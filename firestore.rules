
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && (
        profile().get('role', '').matches('(?i).*(director|odimo|admin).*') ||
        profile().get('role', '').matches('(?i).*vice president.*')
      );
    }

    // --------------------------------------------------------------------------
    // CORE WORKFLOW COLLECTIONS (PRIORITY)
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{id} {
      // Allow all authenticated users to read and write their own or unit requests
      allow read, write: if isSignedIn();
    }

    match /unitForms/{id} {
      allow read, write: if isSignedIn();
    }

    match /submissions/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /risks/{id} {
      allow read, write: if isSignedIn();
    }

    match /employeeActivities/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /wfhActivities/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSupervisor());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // --------------------------------------------------------------------------
    // SYSTEM COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /qaAdvisories/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /auditSchedules/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /auditFindings/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /correctiveActionRequests/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /campuses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /isoClauses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campusSettings/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Final catch-all for anything else
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
