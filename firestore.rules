
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Role Hierarchy Checks
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*(director|odimo|vice president|chair|dean).*');
    }

    // --------------------------------------------------------------------------
    // CORE COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /qaAuditReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviews/{mrId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviewOutputs/{outputId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
      allow update: if isSignedIn();
    }

    match /correctiveActionRequests/{carId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isAuditor();
      allow update: if isAdmin() || isAuditor() || 
        (hasProfile() && resource.data.unitId == profile().get('unitId', ''));
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      // Allow read if user is Admin/Auditor OR if the document belongs to their unit/campus scope
      allow read: if isAdmin() || isAuditor() || (isSignedIn() && hasProfile() && (
        resource.data.userId == request.auth.uid || 
        resource.data.unitId == profile().get('unitId', '') || 
        (isSupervisor() && resource.data.campusId == profile().get('campusId', ''))
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && hasProfile() && (
        resource.data.userId == request.auth.uid || 
        (isSupervisor() && resource.data.campusId == profile().get('campusId', ''))
      ));
      allow delete: if isAdmin();
    }

    match /risks/{riskId} { 
      // Synchronized with Submissions: Allow unit and campus level visibility
      allow read: if isAdmin() || isAuditor() || (isSignedIn() && hasProfile() && (
        resource.data.userId == request.auth.uid || 
        resource.data.unitId == profile().get('unitId', '') || 
        (isSupervisor() && resource.data.campusId == profile().get('campusId', ''))
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && hasProfile() && (
        resource.data.userId == request.auth.uid || 
        (isSupervisor() && resource.data.campusId == profile().get('campusId', ''))
      ));
      allow delete: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // SYSTEM REGISTRIES
    // --------------------------------------------------------------------------

    match /qaAdvisories/{advisoryId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /academicPrograms/{programId} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /programCompliances/{recordId} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /campuses/{campusId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{unitId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{cycleId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    // Announcement & Configuration rules
    match /campusSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSupervisor() && settingId == profile().get('campusId', ''));
    }

    match /procedureManuals/{manualId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /eomsPolicyManuals/{sectionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // AUDIT LOGS & FEEDBACK
    // --------------------------------------------------------------------------

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /errorReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /appFeedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /softwareEvaluations/{evalId} {
      allow read: if isAdmin() || isAuditor();
      allow create: if true; // Public stakeholders can evaluate
    }

    // Catch-all for legacy or other collections
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
