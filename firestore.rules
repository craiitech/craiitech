
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Role Hierarchy Checks
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i)^(Campus Director|Campus ODIMO|Admin|Vice President.*|Director.*)$');
    }

    function isUnitLead() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*(coordinator|odimo|admin).*');
    }

    // --------------------------------------------------------------------------
    // CORE WORKFLOW COLLECTIONS - EXPLICIT RECURSIVE PERMISSIONS
    // Using recursive wildcards {allPaths=**} to ensure collection-level 'list'
    // operations are explicitly authorized for all authenticated users.
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{allPaths=**} { 
      allow read, write: if request.auth != null;
    }

    match /unitForms/{allPaths=**} { 
      allow read, write: if request.auth != null;
    }

    match /submissions/{allPaths=**} { 
      allow read, write: if request.auth != null;
    }
    
    match /risks/{allPaths=**} { 
      allow read, write: if request.auth != null;
    }

    match /formDownloadLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // CORE SYSTEM COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /gadInitiatives/{id} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || (hasProfile() && profile().get('role', '').matches('(?i).*(coordinator|director|odimo|admin).*')));
      allow delete: if isAdmin();
    }

    match /gadMainstreaming/{id} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || (hasProfile() && profile().get('role', '').matches('(?i).*(coordinator|director|odimo|admin).*')));
    }

    match /unitMonitoringRecords/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSupervisor() && profile().role == 'Campus ODIMO'); }
    match /auditSchedules/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isAuditor(); }
    match /auditFindings/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isAuditor(); }
    match /correctiveActionRequests/{carId} { allow read: if isSignedIn(); allow write: if isAdmin() || isAuditor() || isSupervisor(); }
    match /correctiveActionPlans/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /academicPrograms/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /programCompliances/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    
    match /campusSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /qaAdvisories/{advisoryId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /managementReviewOutputs/{outputId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
      allow update: if isSignedIn();
    }

    match /qaAuditReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviews/{mrId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /campuses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /isoClauses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /errorReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /appFeedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /softwareEvaluations/{evalId} {
      allow read: if isAdmin() || isAuditor();
      allow create: if true; 
    }

    match /employeeActivities/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isUnitLead() || isSupervisor() || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Final catch-all for admins
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
