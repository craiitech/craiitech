
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Role Hierarchy Checks
     * Campus and Admin roles are supervisors for approval purposes.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (hasProfile() && profile().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && hasProfile() && profile().get('role', '').matches('(?i)^(Campus Director|Campus ODIMO|Admin|Vice President.*|Director.*)$');
    }

    // --------------------------------------------------------------------------
    // UNIT FORMS & WORKFLOW (PRIORITIZED)
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{id} { 
      allow read, list, write: if isSignedIn();
    }

    match /unitForms/{id} { 
      allow read, list: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --------------------------------------------------------------------------
    // CORE COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /risks/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /unitMonitoringRecords/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSupervisor() && profile().get('role', '') == 'Campus ODIMO'); }
    match /auditSchedules/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isAuditor(); }
    match /auditFindings/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isAuditor(); }
    match /correctiveActionPlans/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /academicPrograms/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || isSupervisor(); }
    match /programCompliances/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    
    match /campusSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSupervisor() && settingId == profile().get('campusId', ''));
    }

    match /qaAdvisories/{advisoryId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /managementReviewOutputs/{outputId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
      allow update: if isSignedIn();
    }

    match /correctiveActionRequests/{carId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /qaAuditReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /managementReviews/{mrId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /campuses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /isoClauses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /system/signatories {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /errorReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /appFeedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /softwareEvaluations/{evalId} {
      allow read: if isAdmin() || isAuditor();
      allow create: if true; 
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
