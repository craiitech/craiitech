
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions - Hardened for safety
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@eoms.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '').matches('(?i)^(Campus Director|Campus ODIMO|Admin|Vice President.*|Director.*)$');
    }

    // --------------------------------------------------------------------------
    // EMPLOYEE ACTIVITIES - Institutional Productivity Log
    // --------------------------------------------------------------------------
    match /employeeActivities/{activityId} {
      // Simplified to benchmark: allow read for all authenticated users to support institutional oversight
      allow read: if isSignedIn();
      // Creation restricted to the authenticated user owning the log entry
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Update/Delete restricted to the owner or System Administrators
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --------------------------------------------------------------------------
    // CORE WORKFLOW COLLECTIONS (Standard Institutional Rules)
    // --------------------------------------------------------------------------
    
    match /submissions/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /risks/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // IQA & QUALITY REGISTRIES
    // --------------------------------------------------------------------------
    
    match /auditPlans/{planId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditSchedules/{scheduleId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAuditor();
    }

    match /auditFindings/{findingId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAuditor();
    }

    match /isoClauses/{clauseId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campuses/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /units/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --------------------------------------------------------------------------
    // SYSTEM CONFIGURATION & AUTHORITY
    // --------------------------------------------------------------------------
    
    match /system/{docId} {
      allow read: if docId == 'settings' || isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /qaAdvisories/{advisoryId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --------------------------------------------------------------------------
    // CATCH-ALL FOR ADMIN OVERRIDE
    // --------------------------------------------------------------------------
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
