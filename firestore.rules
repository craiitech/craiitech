rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions - Hardened for safety
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.matches('(?i).*admin.*'))
      );
    }

    function isAuditor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.matches('(?i).*auditor.*');
    }

    function isSupervisor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.matches('(?i)^(Campus Director|Campus ODIMO|Admin|Vice President.*|Director.*)$');
    }

    // --------------------------------------------------------------------------
    // TOP PRIORITY: IQA & COMPLIANCE ACCESS
    // --------------------------------------------------------------------------
    
    match /auditPlans/{planId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /auditSchedules/{scheduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAuditor();
    }

    match /auditFindings/{findingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isAuditor();
    }

    match /isoClauses/{clauseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // SYSTEM CONFIGURATION
    // --------------------------------------------------------------------------
    
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // GAD CORNER & PCW REPORTING
    // --------------------------------------------------------------------------
    
    match /gadInitiatives/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isSupervisor());
      allow delete: if isAdmin();
    }

    match /gadMainstreaming/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isSupervisor());
    }

    // --------------------------------------------------------------------------
    // UNIT FORMS & WORKFLOW
    // --------------------------------------------------------------------------
    
    match /unitFormRequests/{requestId} { 
      allow read, write: if isSignedIn();
    }

    match /unitForms/{formId} { 
      allow read, write: if isSignedIn();
    }

    match /formDownloadLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // CORE COLLECTIONS
    // --------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /risks/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /unitMonitoringRecords/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isSupervisor(); 
    }
    
    match /correctiveActionRequests/{carId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isAuditor() || isSupervisor(); 
    }

    match /correctiveActionPlans/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /academicPrograms/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || isSupervisor(); 
    }

    match /programCompliances/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }
    
    match /campusSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /qaAdvisories/{advisoryId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    match /managementReviewOutputs/{outputId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
      allow update: if isSignedIn();
    }

    match /managementReviews/{mrId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAuditor();
    }

    match /campuses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /units/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cycles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /procedureManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /eomsPolicyManuals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /errorReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /appFeedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /softwareEvaluations/{evalId} {
      allow read: if isAdmin() || isAuditor();
      allow create: if true; 
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}