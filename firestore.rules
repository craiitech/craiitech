rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions - Hardened for safety
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@eoms.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().get('role', '').matches('(?i).*admin.*'))
      );
    }

    function isSupervisor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().get('role', '').matches('(?i)^(Campus Director|Campus ODIMO|Admin|Vice President.*|Director.*|Auditor)$');
    }

    // --------------------------------------------------------------------------
    // CORE SYSTEM REGISTRIES - PUBLIC READ FOR AUTHENTICATED USERS
    // --------------------------------------------------------------------------
    
    match /programCompliances/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /academicPrograms/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /submissions/{id} { 
      allow read, get, list: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    match /risks/{id} { 
      allow read, get, list: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }

    // --------------------------------------------------------------------------
    // USER PROFILES & AUTHENTICATION
    // --------------------------------------------------------------------------
    match /users/{userId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{id} { 
      allow read, get, list: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --------------------------------------------------------------------------
    // MONITORING & QUALITY ASSURANCE
    // --------------------------------------------------------------------------
    match /unitMonitoringRecords/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /correctiveActionRequests/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /qaAdvisories/{advisoryId} { 
      allow read, get, list: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // --------------------------------------------------------------------------
    // IQA & AUDIT LIFECYCLE
    // --------------------------------------------------------------------------
    match /auditPlans/{planId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /auditSchedules/{scheduleId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /auditFindings/{findingId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /isoClauses/{clauseId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // MANAGEMENT REVIEW & GOVERNANCE
    // --------------------------------------------------------------------------
    match /managementReviews/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // CATCH-ALL FOR ADMIN OVERRIDE
    // --------------------------------------------------------------------------
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // --------------------------------------------------------------------------
    // EMPLOYEE ACTIVITY LOG - APPENDED AT END OF FILE
    // --------------------------------------------------------------------------
    match /employeeActivities/{activityId} {
      allow read, get, list: if isSignedIn() && (request.auth.token.email == 'admin@eoms.com' || isAdmin());
      allow write: if isSignedIn() && (request.auth.token.email == 'admin@eoms.com' || isAdmin() || request.resource.data.userId == request.auth.uid);
    }
  }
}
